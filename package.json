    "docs:serve": "zpress serve"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@zpress/kit": "^0.2.1",
    "oxfmt": "^0.40.0",
    "turbo": "^2.8.17"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@9.15.4"
