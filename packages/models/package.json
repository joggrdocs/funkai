{
  "name": "@funkai/models",
  "version": "0.1.0",
  "private": false,
  "description": "Model catalog, provider resolution, and cost calculations for the funkai AI SDK",
  "keywords": [
    "ai",
    "ai-sdk",
    "models",
    "openrouter",
    "pricing",
    "providers",
    "typescript"
  ],
  "homepage": "https://github.com/joggrdocs/funkai/tree/main/packages/models#readme",
  "bugs": {
    "url": "https://github.com/joggrdocs/funkai/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/funkai.git",
    "directory": "packages/models"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "generate:models": "tsx scripts/generate-models.ts",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --typecheck",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^2.3.0",
    "ai": "^6.0.116",
    "type-fest": "^5.4.4"
  },
  "devDependencies": {
    "@openrouter/sdk": "^0.9.11",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
