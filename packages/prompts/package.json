{
  "name": "@funkai/prompts",
  "version": "0.4.0",
  "private": false,
  "license": "MIT",
  "description": "Prompt SDK with LiquidJS templating and Zod validation",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/funkai.git",
    "directory": "packages/prompts"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.mts",
      "import": "./dist/lib/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown && cp -r src/prompts dist/prompts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "es-toolkit": "^1.45.1",
    "liquidjs": "^10.25.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
