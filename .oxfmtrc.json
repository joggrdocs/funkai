{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "sortImports": {
    "groups": [
      "builtin",
      "external",
      ["internal", "parent", "sibling", "index"],
      "style",
      "unknown"
    ],
    "newlinesBetween": true,
    "internalPattern": ["@/", "@pkg/"],
    "ignoreCase": true,
    "order": "asc"
  },
  "sortPackageJson": true,
  "ignorePatterns": ["**/CHANGELOG.md", ".github/workflows/generate-models.yml"]
}
