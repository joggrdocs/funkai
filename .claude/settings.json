{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(awk:*)",
      "Bash(basename:*)",
      "Bash(cat:*)",
      "Bash(date:*)",
      "Bash(diff:*)",
      "Bash(dirname:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(node:*)",
      "Bash(pnpm:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(test:*)",
      "Bash(touch:*)",
      "Bash(tr:*)",
      "Bash(tsx:*)",
      "Bash(turbo:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Read(./**/*.cjs)",
      "Read(./**/*.css)",
      "Read(./**/*.cts)",
      "Read(./**/*.html)",
      "Read(./**/*.js)",
      "Read(./**/*.json)",
      "Read(./**/*.jsx)",
      "Read(./**/*.md)",
      "Read(./**/*.mdx)",
      "Read(./**/*.mjs)",
      "Read(./**/*.mts)",
      "Read(./**/*.prompt)",
      "Read(./**/*.sh)",
      "Read(./**/*.toml)",
      "Read(./**/*.ts)",
      "Read(./**/*.tsx)",
      "Read(./**/*.txt)",
      "Read(./**/*.yaml)",
      "Read(./**/*.yml)",
      "Skill(plannotator-review:*)",
      "Skill(plannotator-annotate:*)",
      "Skill(tab:*)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:devdocs.io)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.claude.ai)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:docs.npmjs.com)",
      "WebFetch(domain:es-toolkit.slash.page)",
      "WebFetch(domain:esbuild.github.io)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:json-schema.org)",
      "WebFetch(domain:modelcontextprotocol.io)",
      "WebFetch(domain:nodejs.org)",
      "WebFetch(domain:openrouter.ai)",
      "WebFetch(domain:platform.openai.com)",
      "WebFetch(domain:platform.claude.com)",
      "WebFetch(domain:pnpm.io)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:sdk.vercel.ai)",
      "WebFetch(domain:spec.modelcontextprotocol.io)",
      "WebFetch(domain:tc39.es)",
      "WebFetch(domain:turbo.build)",
      "WebFetch(domain:vitest.dev)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:www.typescriptlang.org)",
      "WebFetch(domain:zod.dev)",
      "WebSearch",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id"
    ],
    "deny": [
      "Bash(git clean -df:*)",
      "Bash(git clean -fd:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(find * -delete*)",
      "Bash(find * -exec *)",
      "Bash(find * -ok *)",
      "Bash(rm -fr:*)",
      "Bash(rm -r:*)",
      "Bash(rm -rf:*)",
      "Bash(wget | bash:*)",
      "Bash(wget | sh:*)",
      "Read(./**/*.key)",
      "Read(./**/*.p12)",
      "Read(./**/*.pem)",
      "Read(./**/*.pfx)",
      "Read(./**/*-credentials.json)",
      "Read(./**/*secret*.json)",
      "Read(./**/*secret*.yaml)",
      "Read(./**/*secret*.yml)",
      "Read(./**/*token*.json)",
      "Read(./**/*token*.yaml)",
      "Read(./**/*token*.yml)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/.npmrc)",
      "Read(./**/credentials*.json)",
      "Read(./**/secrets.json)",
      "Read(./**/secrets.yaml)",
      "Read(./**/secrets.yml)",
      "Read(./**/secrets/**)",
      "Read(./**/service-account*.json)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./node_modules/**)",
      "Read(./secrets/**)"
    ],
    "ask": [
      "Bash(cp:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch -d:*)",
      "Bash(git checkout -- *:*)",
      "Bash(git remote add:*)",
      "Bash(git remote set-url:*)",
      "Bash(mv:*)",
      "Bash(pnpm add:*)",
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Bash(xargs:*)"
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "plannotator@plannotator": true,
    "git@joggr": true,
    "gg@joggr": true
  },
  "extraKnownMarketplaces": {
    "joggr": {
      "source": {
        "source": "git",
        "url": "https://github.com/joggrdocs/claude.git"
      }
    },
    "plannotator": {
      "source": {
        "source": "github",
        "repo": "backnotprop/plannotator"
      }
    }
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
